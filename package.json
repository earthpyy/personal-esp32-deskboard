{
  "name": "personal-esp32-deskboard",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:admin": "pnpm --filter admin dev",
    "build:admin": "pnpm --filter admin build",
    "build:api": "pnpm --filter api build",
    "build": "pnpm build:admin && pnpm build:api",
    "start": "pnpm build && pnpm --filter api start"
  }
}
