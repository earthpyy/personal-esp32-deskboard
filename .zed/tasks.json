[
  {
    "label": "firmware: build",
    "command": ".venv/bin/pio run",
    "cwd": "$ZED_WORKTREE_ROOT/apps/firmware"
  },
  {
    "label": "firmware: upload",
    "command": ".venv/bin/pio run -t upload",
    "cwd": "$ZED_WORKTREE_ROOT/apps/firmware"
  },
  {
    "label": "firmware: monitor",
    "command": ".venv/bin/pio device monitor",
    "cwd": "$ZED_WORKTREE_ROOT/apps/firmware"
  },
  {
    "label": "firmware: refresh intellisense",
    "command": ".venv/bin/pio run -t compiledb",
    "cwd": "$ZED_WORKTREE_ROOT/apps/firmware"
  },
  {
    "label": "api: dev",
    "command": "mise exec -- npx -y pnpm@10 --filter api dev",
    "cwd": "$ZED_WORKTREE_ROOT"
  }
]
