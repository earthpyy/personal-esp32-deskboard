# Copy this file to .env (gitignored) and fill in real values.
# From your Google Cloud OAuth web-application client (see README):
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Todoist personal API token (Todoist → Settings → Integrations → Developer).
# Leave unset to disable the Todoist tab. Pick which saved filter to show in the
# admin UI's Todoist tab.
TODOIST_TOKEN=your-todoist-api-token

# Port the API listens on (default 3300). Changing it means updating the board's
# API_BASE_URL (reflash) and the redirect URI on the Google OAuth client.
# PORT=3300
